{% from "../../../macros/summaryCardMacro.njk" import summaryCard %}
{% from "../../../macros/summaryListRow.njk" import summaryListRow %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set age = personalDetails.personalDetailsMain.age.years + " years, " + personalDetails.personalDetailsMain.age.months | pluralise('month') if personalDetails.personalDetailsMain.age else "Not entered" %}
{% set inCaseload = isInUsersCaseLoad(prisonId, user) %}
{% set grantedReligion = isGranted(PersonProtectedCharacteristicsPermission.read_religion_and_belief, prisonerPermissions) %}
{% set moveEthnicGroup = hideSomePersonalOverviewInfo and ((not inCaseload) or (not grantedReligion)) %}
{%- call summaryCard({title: "Personal"}) -%}
  <div class="govuk-grid-row" data-qa="personal-details">
    <div class="govuk-grid-column-one-half hmpps-full-width-print">
      <dl class="govuk-summary-list govuk-summary-list--no-border">
        {{ summaryListRow("Date of birth", personalDetails.personalDetailsMain.dateOfBirth or 'Not entered', "date-of-birth") }}
        {{ summaryListRow("Age", age, "age") }}
        {% if moveEthnicGroup %}
          {{ summaryListRow("Ethnic group", personalDetails.personalDetailsSide.ethnicGroup or 'Not entered', "ethnic-group") }}
        {% endif %}
        {% if hideSomePersonalOverviewInfo %}
          {% if inCaseload %}
            {{ summaryListRow("Nationality", personalDetails.personalDetailsMain.nationality or 'Not entered', "nationality") }}
            {{ summaryListRow("Spoken language", personalDetails.personalDetailsMain.spokenLanguage or 'Not entered', "spoken-language") }}
          {% endif %}
          {% if grantedReligion %}
            {{ summaryListRow("Religion, faith or belief", personalDetails.personalDetailsSide.religionOrBelief or 'Not entered', "religion-or-belief") }}
          {% endif %}
        {% else %}
          {{ summaryListRow("Nationality", personalDetails.personalDetailsMain.nationality or 'Not entered', "nationality") }}
          {{ summaryListRow("Spoken language", personalDetails.personalDetailsMain.spokenLanguage or 'Not entered', "spoken-language") }}
          {{ summaryListRow("Religion, faith or belief", personalDetails.personalDetailsSide.religionOrBelief or 'Not entered', "religion-or-belief") }}
        {% endif %}
      </dl>
    </div>
    <div class="govuk-grid-column-one-half hmpps-full-width-print">
      <dl class="govuk-summary-list govuk-summary-list--no-border">
        {% if not moveEthnicGroup %}
          {{ summaryListRow("Ethnic group", personalDetails.personalDetailsSide.ethnicGroup or 'Not entered', "ethnic-group") }}
        {% endif %}
        {{ summaryListRow("CRO number", personalDetails.personalDetailsSide.croNumber or 'Not entered', "cro-number") }}
        {{ summaryListRow("PNC number", personalDetails.personalDetailsSide.pncNumber or 'Not entered', "pnc-number") }}
      </dl>
    </div>
  </div>
{%- endcall -%}
