{% from "./macros/statusListMacro.njk" import statusList %}
{% from "components/miniCard/miniCard.njk" import miniCard %}

<div class="govuk-grid-row">
  <section class="govuk-grid-column-full" aria-label="Status List">
    {{ statusList(statuses) }}
  </section>
</div>

{% call conditionallyShow({
  id: 'ccard-edit',
  condition: options.showCourtCaseSummary
}) %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% include "./courtCases/courtCasesAndReleaseDates.njk" %}
    </div>
  </div>
{% endcall %}

<div class="govuk-grid-row hmpps-miniSummaryWrapper" data-qa="overview-mini-summary-group-a">
  {% include "./money/money.njk" %}
  {% include "./visits/visits.njk" %}
  {% include "./nonAssociation/nonAssociation.njk" %}
</div>

<div class="govuk-grid-row hmpps-miniSummaryWrapper" data-qa="overview-mini-summary-group-b">
  {% include "./externalContacts/externalContacts.njk" %}
  {% include "./staffContacts/staffContactsWrapper.njk" %}
</div>

<div class="govuk-grid-row hmpps-miniSummaryWrapper" data-qa="overview-mini-summary-group-c">
  {% include "./adjudications/adjudications.njk" %}
  {% include "./incentives/incentives.njk" %}
</div>

<div class="govuk-grid-row hmpps-miniSummaryWrapper" data-qa="overview-mini-summary-group-d">
  {% include "./category/category.njk" %}
  {% include "./csra/csra.njk" %}
  {% include "./csip/csip.njk" %}
</div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    {% include "./personalDetails/personalDetails.njk" %}
  </div>
</div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    {% call conditionallyShow({
      id: 'overview-schedule',
      condition: isGranted(PrisonerSchedulePermission.read_schedule, prisonerPermissions)
    }) %}
      {% include "./schedule/schedule.njk" %}
    {% endcall %}
  </div>
</div>

{% call conditionallyShow({
  id: 'ccard-readonly',
  condition: (
  not options.showCourtCaseSummary
  and offencesMoved(user.activeCaseLoadId)
  and isGranted(PersonSentenceCalculationPermission.read, prisonerPermissions)
  )
}) %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% include "./releaseDate/confirmedReleaseDate.njk" %}
    </div>
  </div>
{% endcall %}


{# TODO: remove this once we have fully moved the offences tab data away to CCARD: #}
{% call conditionallyShow({
  id: 'old-offences-card',
  condition: not options.showCourtCaseSummary and not offencesMoved(user.activeCaseLoadId)
}) %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full" data-qa="overview-offences">
      {% include "./offences/offences.njk" %}
    </div>
  </div>
{% endcall %}
