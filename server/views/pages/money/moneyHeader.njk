{% from "macros/hmppsTabs.njk" import hmppsTabs %}
{% block body %}

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-three-quarters">
            <h1 class="govuk-heading-l govuk-!-margin-top-1 govuk-!-margin-bottom-8">{{ prisonerName | apostrophe }} money</h1>
        </div>
    </div>

    {{ hmppsTabs({
        currentUrlPath: currentUrlPath,
        testIdPrefix: 'money-tabs-',
        tabs: [
            { text: 'Spends', url: '/prisoner/' + prisonerNumber + '/money/spends', visible: true, testId: 'spends' },
            { text: 'Private cash', url: '/prisoner/' + prisonerNumber + '/money/private-cash', visible: true, testId: 'privateCash' },
            { text: 'Savings', url: '/prisoner/' + prisonerNumber + '/money/savings', visible: true, testId: 'savings' },
            { text: 'Damage obligations', url: '/prisoner/' + prisonerNumber + '/money/damage-obligations', visible: showDamageObligationsTab, testId: 'damageObligations' }
        ]
    }) }}

{%  endblock %}
