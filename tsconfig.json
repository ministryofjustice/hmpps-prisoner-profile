{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    "isolatedModules": true,
    "rootDir": ".",
    "outDir": "./dist",
    "sourceMap": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "strict": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "typeRoots": ["./server/@types", "./node_modules/@types"],
    "types": ["node", "jest"]
  },
  "exclude": [
    "node_modules/",
    "assets/",
    "integration_tests/",
    "dist/",
    "cypress.config.ts",
    "coverage/",
    "esbuild/",
    "eslint.config.mjs"
  ],
  "include": ["**/*.js", "**/*.ts"]
}
